{
  "name": "devsec-nutriapp",
  "version": "1.0.0",
  "description": "NutriApp - Système de recommandation nutritionnelle sécurisé",
  "main": "main.js",
  "scripts": {
    "start": "npx -y http-server ./ -c-1",
    "electron-dev": "electron .",
    "electron-pack": "electron-builder build --win --publish never"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "mysql2": "^3.2.0"
  },
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1"
  },
  "build": {
    "appId": "com.nutriapp.secure",
    "productName": "NutriApp Secure",
    "files": [
      "**/*",
      "backend/.env",
      "main.js",
      "preload.js",
      "index.html",
      "style.css",
      "!dist/*",
      "!Caches/*"
    ],
    "directories": {
      "output": "dist_prod"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
